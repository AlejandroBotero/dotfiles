default partial alphanumeric_keys
xkb_symbols "custom" {

    include "pc"
    include "us dvorak"
    include "level3(ralt_switch)"

    // --- Top row ---
    key <AD11> { [ dead_grave, dead_circumflex ] };

    // --- Home row ---
    key <AC11> { [ dead_acute, dead_diaeresis, dead_tilde, dead_tilde ] };

    // --- Bottom row ---
    key <AB01> { [ ntilde, Ntilde, 7, EuroSign ] };
};

